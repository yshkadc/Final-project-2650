<%- include('partials/header') %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Item</h5>
        </div>
        <div class="card-body p-4">

          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
              <i class="bi bi-exclamation-triangle me-1"></i><%= error %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <form action="/items/edit/<%= item._id %>" method="POST" novalidate>

            <!-- Name -->
            <div class="mb-3">
              <label for="name" class="form-label fw-semibold">Item Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="name" name="name"
                     value="<%= item.name %>" required>
            </div>

            <!-- Category + Location -->
            <div class="row g-3 mb-3">
              <div class="col-sm-6">
                <label for="category" class="form-label fw-semibold">Category</label>
                <select class="form-select" id="category" name="category">
                  <% ['fridge','pantry','medicine','cleaning','other'].forEach(cat => { %>
                    <option value="<%= cat %>" <%= item.category === cat ? 'selected' : '' %>>
                      <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
                    </option>
                  <% }); %>
                </select>
              </div>
              <div class="col-sm-6">
                <label for="location" class="form-label fw-semibold">Location</label>
                <input type="text" class="form-control" id="location" name="location"
                       value="<%= item.location %>">
              </div>
            </div>

            <!-- Quantity + Unit -->
            <div class="row g-3 mb-3">
              <div class="col-sm-6">
                <label for="quantity" class="form-label fw-semibold">Quantity</label>
                <input type="number" class="form-control" id="quantity" name="quantity"
                       value="<%= item.quantity %>" min="0" step="0.1">
              </div>
              <div class="col-sm-6">
                <label for="unit" class="form-label fw-semibold">Unit</label>
                <select class="form-select" id="unit" name="unit">
                  <% ['pcs','L','mL','kg','g','box','bottle','pack'].forEach(u => { %>
                    <option value="<%= u %>" <%= item.unit === u ? 'selected' : '' %>><%= u %></option>
                  <% }); %>
                </select>
              </div>
            </div>

            <!-- Expiry Date -->
            <div class="mb-3">
              <label for="expiryDate" class="form-label fw-semibold">Expiry Date</label>
              <input type="date" class="form-control" id="expiryDate" name="expiryDate"
                     value="<%= item.expiryDate ? new Date(item.expiryDate).toISOString().split('T')[0] : '' %>">
            </div>

            <!-- Notes -->
            <div class="mb-4">
              <label for="notes" class="form-label fw-semibold">Notes</label>
              <textarea class="form-control" id="notes" name="notes" rows="2"><%= item.notes %></textarea>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary flex-grow-1">
                <i class="bi bi-check-lg me-2"></i>Save Changes
              </button>
              <a href="/items/dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg"></i> Cancel
              </a>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
