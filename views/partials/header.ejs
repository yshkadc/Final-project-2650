<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SmartHome Tracker</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- ── Navbar (Bootstrap Responsive Navbar) ── -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <a class="navbar-brand" href="/">
      <i class="bi bi-house-gear-fill me-2 text-info"></i>SmartHome Tracker
    </a>
    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

        <li class="nav-item">
          <a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a>
        </li>

        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/items/dashboard">
              <i class="bi bi-grid me-1"></i>Dashboard
            </a>
          </li>

          <% if (user.role === 'admin' || user.role === 'member') { %>
            <li class="nav-item">
              <a class="nav-link" href="/items/add">
                <i class="bi bi-plus-circle me-1"></i>Add Item
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-info" href="/items/scan">
                <i class="bi bi-upc-scan me-1"></i>Scan
              </a>
            </li>
          <% } %>

          <% if (user.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link text-warning" href="/admin">
                <i class="bi bi-shield-lock me-1"></i>Admin
              </a>
            </li>
          <% } %>

          <li class="nav-item">
            <span class="navbar-text me-2">
              <span class="badge bg-<%= user.role === 'admin' ? 'danger' : user.role === 'member' ? 'primary' : 'secondary' %>">
                <%= user.role %>
              </span>
              <%= user.username %>
            </span>
          </li>
          <li class="nav-item">
            <a class="btn btn-outline-light btn-sm" href="/logout">
              <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
          </li>

        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login"><i class="bi bi-person me-1"></i>Login</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-info btn-sm text-white" href="/register">
              <i class="bi bi-person-plus me-1"></i>Register
            </a>
          </li>
        <% } %>

      </ul>
    </div>
  </div>
</nav>
<!-- ── End Navbar ── -->
