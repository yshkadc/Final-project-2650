<%- include('partials/header') %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow border-0">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Add New Item</h5>
        </div>
        <div class="card-body p-4">

          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
              <i class="bi bi-exclamation-triangle me-1"></i><%= error %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <form action="/items/add" method="POST" novalidate>

            <!-- Barcode Quick-Fill -->
            <div class="mb-3">
              <label class="form-label fw-semibold">Barcode (optional)</label>
              <div class="input-group">
                <input type="text" class="form-control" id="barcodeField" name="barcode"
                       placeholder="Scan or enter barcode..." maxlength="14">
                <button class="btn btn-info text-white" type="button" id="quickLookupBtn">
                  <i class="bi bi-upc-scan me-1"></i>Look Up
                </button>
              </div>
              <small class="text-muted">Auto-fills product name, category, and expiry date.</small>
              <div id="lookupStatus" class="small mt-1 d-none"></div>
            </div>

            <!-- Name -->
            <div class="mb-3">
              <label for="name" class="form-label fw-semibold">Item Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="name" name="name"
                     placeholder="e.g. Milk, Ibuprofen, Bleach..." required>
            </div>

            <!-- Category + Location (2-col grid) -->
            <div class="row g-3 mb-3">
              <div class="col-sm-6">
                <label for="category" class="form-label fw-semibold">Category</label>
                <select class="form-select" id="category" name="category">
                  <option value="fridge">🧊 Fridge</option>
                  <option value="pantry" selected>🧺 Pantry</option>
                  <option value="medicine">💊 Medicine</option>
                  <option value="cleaning">🧹 Cleaning</option>
                  <option value="other">📦 Other</option>
                </select>
              </div>
              <div class="col-sm-6">
                <label for="location" class="form-label fw-semibold">Location</label>
                <input type="text" class="form-control" id="location" name="location"
                       placeholder="e.g. Kitchen, Bathroom" value="Home">
              </div>
            </div>

            <!-- Quantity + Unit (2-col grid) -->
            <div class="row g-3 mb-3">
              <div class="col-sm-6">
                <label for="quantity" class="form-label fw-semibold">Quantity</label>
                <input type="number" class="form-control" id="quantity" name="quantity"
                       value="1" min="0" step="0.1">
              </div>
              <div class="col-sm-6">
                <label for="unit" class="form-label fw-semibold">Unit</label>
                <select class="form-select" id="unit" name="unit">
                  <option value="pcs">pcs</option>
                  <option value="L">L</option>
                  <option value="mL">mL</option>
                  <option value="kg">kg</option>
                  <option value="g">g</option>
                  <option value="box">box</option>
                  <option value="bottle">bottle</option>
                  <option value="pack">pack</option>
                </select>
              </div>
            </div>

            <!-- Expiry Date -->
            <div class="mb-3">
              <label for="expiryDate" class="form-label fw-semibold">Expiry Date</label>
              <input type="date" class="form-control" id="expiryDate" name="expiryDate">
              <small class="text-muted">Leave blank if the item has no expiry date.</small>
            </div>

            <!-- Notes -->
            <div class="mb-4">
              <label for="notes" class="form-label fw-semibold">Notes</label>
              <textarea class="form-control" id="notes" name="notes" rows="2"
                        placeholder="Optional notes..."></textarea>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-success flex-grow-1">
                <i class="bi bi-check-lg me-2"></i>Add Item
              </button>
              <a href="/items/dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg"></i> Cancel
              </a>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
(function() {
  const lookupBtn = document.getElementById('quickLookupBtn');
  const barcodeField = document.getElementById('barcodeField');
  const statusDiv = document.getElementById('lookupStatus');
  if (!lookupBtn) return;

  lookupBtn.addEventListener('click', doLookup);
  barcodeField.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); doLookup(); }});

  async function doLookup() {
    const code = barcodeField.value.trim();
    if (!code) return;
    statusDiv.classList.remove('d-none');
    statusDiv.innerHTML = '<span class="text-info"><i class="bi bi-hourglass-split"></i> Looking up...</span>';
    try {
      const res = await fetch(`/api/barcode/${encodeURIComponent(code)}`);
      const json = await res.json();
      if (json.success) {
        const d = json.data;
        if (d.name) document.getElementById('name').value = d.name;
        if (d.suggestedExpiry) document.getElementById('expiryDate').value = d.suggestedExpiry;
        if (d.category) {
          const sel = document.getElementById('category');
          for (let o of sel.options) o.selected = (o.value === d.category);
        }
        if (d.brand) document.getElementById('notes').value = 'Brand: ' + d.brand;
        statusDiv.innerHTML = `<span class="text-success"><i class="bi bi-check-circle"></i> Found: ${d.name || 'Product'}</span>`;
      } else {
        statusDiv.innerHTML = `<span class="text-danger"><i class="bi bi-x-circle"></i> ${json.message}</span>`;
      }
    } catch {
      statusDiv.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle"></i> Network error.</span>';
    }
  }
})();
</script>
